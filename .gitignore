# ============================================================
# VagaSolar — .gitignore
# MERN Monorepo: React (CRA) + Node/Express + MongoDB Atlas
# ============================================================


# --- Dependencies ---
node_modules/
frontend/node_modules/
backend/node_modules/


# --- Environment & Secrets ---
# Protects: MONGO_URI, JWT_SECRET, Cloudinary keys
.env
.env.local
.env.production
frontend/.env
frontend/.env.local
frontend/.env.production
frontend/.env.production.local
backend/.env
backend/.env.local


# --- Build Artifacts ---
# React (CRA) output
frontend/build/
# Vite output
frontend/dist/
# Generic / backend compile output
dist/
build/


# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
backend/security.log


# --- OS & IDE Junk ---
.DS_Store
Thumbs.db
.vscode/
.idea/


# --- Testing & Coverage ---
coverage/
frontend/coverage/
backend/coverage/


# --- Runtime ---
*.pid
*.pid.lock